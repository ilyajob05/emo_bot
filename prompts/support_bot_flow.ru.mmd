flowchart TD
    A[Сообщение пользователя] --> B[strategy_suggest]

    B --> C{should_escalate_now?}

    C -->|Да| D[Передать оператору]
    D --> D1["Клиенту: 'Передаю специалисту...'"]
    D1 --> D2["[SYSTEM] Контекст эскалации для оператора"]

    C -->|Нет| E{Нужны данные заказа?}

    E -->|Да| F[order_lookup]
    F --> G[Составить ответ]

    E -->|Нет| G

    G --> H{Обнаружена emotion_escalation?}

    H -->|Да| I[emotion_de_escalate]
    I --> J[Отправить ответ клиенту]

    H -->|Нет| J

    J --> K["[SYSTEM] Лог результатов"]
    K --> L[Ожидание сообщения]
    L --> A

    %% strategy_suggest details
    B -.->|возвращает| B1["recommended_strategy
    action_sequence
    anti_patterns
    escalation
    detected_patterns"]

    %% Detected patterns
    B1 -.-> P1["Паттерны:
    repeated_question
    legal_threat
    human_request
    churn_signal
    emotion_escalation
    no_progress
    repeated_contact"]

    style A fill:#4A90D9,color:#fff
    style D fill:#E74C3C,color:#fff
    style D1 fill:#E74C3C,color:#fff
    style D2 fill:#E74C3C,color:#fff
    style F fill:#27AE60,color:#fff
    style I fill:#F39C12,color:#fff
    style J fill:#4A90D9,color:#fff
    style B fill:#8E44AD,color:#fff
    style B1 fill:#D5B8E8,color:#333
    style P1 fill:#FADBD8,color:#333
    style K fill:#BDC3C7,color:#333
